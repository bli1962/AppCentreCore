@page "/GetCovenantRatio"
@inherits GetCovenantRatioBase



@*<body style="padding-top:20px">*@
<div class="container-fluid">

	@if (modelView == null && SelectedCovenantType != "")
	{
		<div class="spinner"></div>
	}
	else
	{
		@*Section 1 - Title *@
		<div class="row ">
			<div class="col-sm-12">
				<h3></h3>
			</div>
			<div class="col-sm-6">
				<div class="panel panel-primary" style="color: blue; border-color: #ffffff; ">
					<div class="panel-body"><h4>Display Covenant Ratio Report</h4></div>
				</div>
			</div>
		</div>

		@*<div class="row ">
				<div class="col-md-12">
					<div id="divBasicAuthUsername">
					</div>
				</div>
			</div>*@

		@*Section 2 - Parameters*@
		<div class="row">
			<div class="col-md-4">
				<div id="DivSpanUsername" class="well hidden">
					<span id="spanUsername" class="text-muted"></span>
				</div>
				<table class="table table-sm table-bordered table-AppCenter">
					<tbody thead class="thead-light">
						<tr>
							<td>Covenant Type: </td>
							<td>
								<select class="form-control" @bind="SelectedCovenantType">
									<option value="Covenant">Covenant</option>
								</select>
							</td>
						</tr>
					</tbody>
				</table>

				<div class="well">
					<button class="btn btn-outline-primary m-1 float-left" @onclick="SearchClick">Search</button>

					<input id="btnCopy" class="btn btn-outline-info m-1 float-left" type="button" value="Copy"
						   onclick="selectElementContents( document.getElementById('report_container') );" />

					<button class="btn btn-outline-primary m-1 float-left" @onclick="BackClick">Back</button>
				</div>
			</div>
		</div>

		@*<div class="d-flex justify-content-center">
				<div class="spinner-grow text-primary" id="spinner" role="status" style="display:none;width: 6rem; height: 6rem;">
					<span class="sr-only">Loading...</span>
				</div>
			</div>*@


		@*Section 3 - list display*@
		<div id="report_container">
			<div class="row ">
				<div class="col-md-12">
					<div id="divData" class="hidden">
						<table class="table table-sm table-striped table-hover table-AppCenter" id="tblData">
							<thead class="table-dark Col-Head">
								<tr>
									<th>Covenant No</th>
									<th>Record No</th>
									<th>Cust. Abbr</th>
									<th>CCIF Nname</th>
									<th>Type</th>
									<th>Condition Group</th>
									<th>Ratio</th>
									<th>Rate</th>
									<th>Rate Adj</th>
									<th>Adj Date</th>
									<th>Report Date</th>
									<th>Due Date</th>
									<th>Received Date</th>
								</tr>
							</thead>
							<tbody Class="table-active Row-Cell">
								@foreach (var item in modelView)
								{
									<tr>
										<td>@item.COVENANT_NO</td>
										<th>@item.RECORD_NO</th>
										<th>@item.CUST_ABBR</th>
										<th>@item.CCIF_NAME</th>
										<th>@item.COVENANT_DECS</th>
										<th>@item.CONDITION_GROUP_DESC</th>
										<th>@item.CONDITION_DESC</th>
										<th>@item.RATE</th>
										<th>@item.RATE_ADJ</th>
										<th>@item.DATE_RECIEVED_ADJ</th>
										<th>@item.REPORT_DATE</th>
										<th>@item.DUE_DATE</th>
										<th>@item.DATE_RECIEVED</th>
								
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	}
</div>
@*the component take two parameters*@
<ConfirmYes @ref="ComfirmationComponent"
			ConfirmationChanged="ConfirmClick"
			ConfirmationTitle=@($"Bank Information")
			ConfirmationMessage=@($"No Bank Information found.")
			BtnClass=@($"btn btn-primary float-left")
			YesTitle=@($"Ok")>
</ConfirmYes>
@*</body>*@